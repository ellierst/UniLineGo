<Window x:Class="UniLineGo.Presentation.Views.ReminderNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UniLineGo"
        Width="340"
        Height="Auto"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
            <DoubleAnimation Storyboard.TargetName="Translate"
                             Storyboard.TargetProperty="Y"
                             From="30" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideOut" Completed="SlideOut_Completed">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="Translate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="20" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="Root" CornerRadius="14"
            Background="White"
            Margin="12,12,12,12"
            Padding="0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="Translate"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4"
                              Opacity="0.18" Color="#3D3047"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Accent stripe -->
            <Border Grid.Row="0" Background="#a78dc4" CornerRadius="14,14,0,0"/>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,14,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Emoji icon -->
                <Border Grid.Column="0"
                        Background="#F0EBF4" CornerRadius="10"
                        Width="42" Height="42"
                        Margin="0,0,12,0"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="EmojiText"
                               Text="⏰"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Text -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Нагадування"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#9A8A9E"
                               Margin="0,0,0,3"/>
                    <TextBlock x:Name="TitleText"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#3D3047"
                               TextWrapping="Wrap"
                               MaxWidth="200"/>
                    <TextBlock x:Name="BodyText"
                               FontSize="12"
                               Foreground="#6B5B7B"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0"
                               MaxWidth="200"/>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="2"
                        Content="✕"
                        FontSize="12"
                        Foreground="#B0A4BA"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Top"
                        Padding="4"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent"
                                    CornerRadius="6" Padding="4">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#F0EBF4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
