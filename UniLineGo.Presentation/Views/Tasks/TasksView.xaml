<UserControl x:Class="UniLineGo.Presentation.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style x:Key="FilterTabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#9A8A9E"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#F5F2F0" Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Завдання"
                   FontSize="28" FontWeight="Bold"
                   Foreground="#C3B3D4" Margin="0,0,0,20"/>

        <!-- Search + Add -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8"
                    BorderBrush="#E0DAE6" BorderThickness="1" Margin="0,0,12,0">
                <Grid>
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="Пошук завдань..."
                               Foreground="#C3B3D4" FontSize="13"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#5A4E6D" FontSize="13"
                             Height="40" Padding="12,0"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>
                </Grid>
            </Border>

            <Button Grid.Column="1" Content="+ Додати завдання"
                    Height="40" Padding="18,0"
                    FontSize="13" FontWeight="SemiBold"
                    Cursor="Hand" Click="AddTask_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="#C3B3D4" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#b3a3c4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Filter tabs -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <Grid x:Name="TabsContainer">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="TabAll" Content="Всі"
                            Style="{StaticResource FilterTabStyle}"
                            Click="TabAll_Click"
                            Foreground="#5A4E6D" FontWeight="SemiBold"/>
                    <Button x:Name="TabPending" Content="На виконання"
                            Style="{StaticResource FilterTabStyle}"
                            Click="TabPending_Click"/>
                    <Button x:Name="TabDone" Content="Виконано"
                            Style="{StaticResource FilterTabStyle}"
                            Click="TabDone_Click"/>
                    <Button x:Name="TabOverdue" Content="Прострочено"
                            Style="{StaticResource FilterTabStyle}"
                            Click="TabOverdue_Click"/>
                </StackPanel>
            </Grid>
            <!-- Індикатор окремим рядком, керується через Margin -->
            <Border x:Name="TabIndicator"
                    Height="2" Background="#6B5B7B"
                    HorizontalAlignment="Left"
                    Width="44" Margin="14,0,0,0"/>
        </StackPanel>

        <!-- Task list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <ItemsControl x:Name="TasksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent"
                                Padding="0,10"
                                BorderBrush="#EDE8ED"
                                BorderThickness="0,0,0,1"
                                MouseEnter="TaskRow_MouseEnter"
                                MouseLeave="TaskRow_MouseLeave">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- Checkbox -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                          VerticalAlignment="Center"
                                          Checked="TaskCheck_Changed"
                                          Unchecked="TaskCheck_Changed"
                                          Tag="{Binding Id}"/>

                                <!-- Title -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="14" Foreground="#b3a3c4"
                                           FontWeight="Medium"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>

                                <!-- Status badge — no BasedOn, standalone style -->
                                <Border Grid.Column="2"
                                        CornerRadius="12" Padding="10,4"
                                        Margin="0,0,16,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0EBF4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Виконано">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="На виконання">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Прострочено">
                                                    <Setter Property="Background" Value="#FDECEA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="12" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#9A8A9E"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Виконано">
                                                        <Setter Property="Foreground" Value="#388E3C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="На виконання">
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Прострочено">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Deadline -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding DeadlineText}"
                                           FontSize="13" Foreground="#9A8A9E"
                                           VerticalAlignment="Center"/>

                                <!-- Edit / Delete -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal"
                                            VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="&#x270E;" FontSize="14"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Foreground="#b3a3c4" Padding="6,4"
                                            Click="EditTask_Click" Tag="{Binding Id}"/>
                                    <Button Content="&#x2715;" FontSize="13"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Foreground="#b3a3c4" Padding="6,4"
                                            Click="DeleteTask_Click" Tag="{Binding Id}"/>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <TextBlock Grid.Row="4" x:Name="FooterCount"
                   FontSize="12" Foreground="#9A8A9E" Margin="0,12,0,0"/>

    </Grid>
</UserControl>
