<UserControl x:Class="UniLineGo.Presentation.Views.TaskDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F2F0" Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Margin="0,0,0,24" VerticalAlignment="Center">
            <Button Content="←"
                    FontSize="20"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Foreground="#6B5B7B"
                    Padding="0,0,12,0"
                    Click="BackButton_Click"/>
            <TextBlock Text="Деталі завдання"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#3D3047"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Content Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="12"
                Padding="32,28" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#6B5B7B"/>
            </Border.Effect>

            <StackPanel>

                <!-- Status Badge -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border x:Name="StatusBadge" CornerRadius="12" Padding="14,5">
                        <TextBlock x:Name="StatusText" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Title -->
                <TextBlock Text="Назва"
                           Foreground="#9A8A9E" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TitleText"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#3D3047"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- Description -->
                <TextBlock Text="Опис"
                           Foreground="#9A8A9E" FontSize="12" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Border Background="#F5F2F0" CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
                    <TextBlock x:Name="DescriptionText"
                               FontSize="14" Foreground="#5A4E6D"
                               TextWrapping="Wrap" MinHeight="48"/>
                </Border>

                <!-- Deadline + Completed row -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Дедлайн"
                                   Foreground="#9A8A9E" FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <Border Background="#F5F2F0" CornerRadius="8" Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeadlineText"
                                           FontSize="14" Foreground="#3D3047"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Виконання"
                                   Foreground="#9A8A9E" FontSize="12" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <Border Background="#F5F2F0" CornerRadius="8" Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                               <CheckBox x:Name="CompletedCheck"
                                         VerticalAlignment="Center"
                                         Cursor="Hand"
                                         Click="CompletedCheck_Click"
                                         Margin="0,0,10,0">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <Border x:Name="Box"
                                                                Width="20" Height="20"
                                                                CornerRadius="5"
                                                                BorderThickness="2"
                                                                BorderBrush="#C3B3D4"
                                                                Background="White">
                                                            <TextBlock x:Name="Check"
                                                                    Text="✓"
                                                                    FontSize="12"
                                                                    FontWeight="Bold"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="Collapsed"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Box" Property="Background" Value="#6B5B7B"/>
                                                                <Setter TargetName="Box" Property="BorderBrush" Value="#6B5B7B"/>
                                                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Box" Property="BorderBrush" Value="#6B5B7B"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>

                                <TextBlock x:Name="CompletedText"
                                           FontSize="14" Foreground="#3D3047"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Action Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Редагувати"
                            Height="46" FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand" Click="EditButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="#a78dc4" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#8e75a9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2" Content="Видалити"
                            Height="46" FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand" Click="DeleteButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="#fde6a5" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="#a78dc4"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#f4d785"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
