<UserControl x:Class="UniLineGo.Presentation.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#EBDEC0">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#768E78" Padding="24,0">
            <Grid>
                <TextBlock Text="UniLineGo" FontSize="20" FontWeight="Bold"
                           Foreground="White" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <Button x:Name="ProfileButton" Content="👤 Профіль"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"
                        FontFamily="Segoe UI" Click="ProfileButton_Click"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="Головна сторінка"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" Foreground="#768E78" FontFamily="Segoe UI"
                   FontWeight="SemiBold"/>
    </Grid>
</UserControl>