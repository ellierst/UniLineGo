<UserControl x:Class="UniLineGo.Presentation.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="#EDE8ED">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#C3B3D4" Padding="24,0">
            <Grid>
                <TextBlock Text="UniLineGo"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button x:Name="ProfileButton"
                        Content="👤 Профіль"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontSize="13"
                        Click="ProfileButton_Click"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <TextBlock Grid.Row="1"
                   Text="Головна сторінка"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="24"
                   Foreground="#C3B3D4"
                   FontWeight="SemiBold"/>
    </Grid>
</UserControl>