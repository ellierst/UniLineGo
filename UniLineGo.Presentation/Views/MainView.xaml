<UserControl x:Class="UniLineGo.Presentation.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Resources MUST come before usage -->
    <UserControl.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Foreground" Value="#E8E0EE"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#7D6B8E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F2F0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════ SIDEBAR ═══════════ -->
        <Border Grid.Column="0" Background="#6B5B7B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="72"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" BorderBrush="#7D6B8E" BorderThickness="0,0,0,1">
                    <TextBlock Text="UniLineGo"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="24,0"/>
                </Border>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="0,16,0,0">

                    <Button x:Name="NavHome"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavHome_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2302;" FontSize="16" Width="24"
                                       VerticalAlignment="Center" Foreground="#E8E0EE"/>
                            <TextBlock Text="Головна" VerticalAlignment="Center" Foreground="#E8E0EE"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavTasks"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2713;" FontSize="16" Width="24"
                                       VerticalAlignment="Center" Foreground="#E8E0EE"/>
                            <TextBlock Text="Завдання" VerticalAlignment="Center" Foreground="#E8E0EE"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavCalendar"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavCalendar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25A6;" FontSize="16" Width="24"
                                       VerticalAlignment="Center" Foreground="#E8E0EE"/>
                            <TextBlock Text="Календар" VerticalAlignment="Center" Foreground="#E8E0EE"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavReminders"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavReminders_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F514;" FontSize="14" Width="24"
                                       VerticalAlignment="Center" Foreground="#E8E0EE"/>
                            <TextBlock Text="Нагадування" VerticalAlignment="Center" Foreground="#E8E0EE"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavStats"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavStats_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2197;" FontSize="16" Width="24"
                                       VerticalAlignment="Center" Foreground="#E8E0EE"/>
                            <TextBlock Text="Статистика" VerticalAlignment="Center" Foreground="#E8E0EE"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="NavSettings"
                            Style="{StaticResource NavButtonStyle}"
                            Click="NavSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="16" Width="24"
                                       VerticalAlignment="Center" Foreground="#E8E0EE"/>
                            <TextBlock Text="Налаштування" VerticalAlignment="Center" Foreground="#E8E0EE"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Logout -->
                <Border Grid.Row="2" BorderBrush="#7D6B8E" BorderThickness="0,1,0,0" Padding="0,8">
                    <Button Click="LogoutButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Left"
                            Padding="24,10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2192;" FontSize="16" Width="24"
                                                   Foreground="#DACADD" VerticalAlignment="Center"/>
                                        <TextBlock Text="Вийти" FontSize="14"
                                                   Foreground="#DACADD" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

            </Grid>
        </Border>

        <!-- ═══════════ CONTENT AREA ═══════════ -->
        <ContentControl x:Name="ContentArea" Grid.Column="1"/>

    </Grid>
</UserControl>
