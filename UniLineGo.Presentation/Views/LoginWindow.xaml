<Window x:Class="UniLineGo.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UniLineGo" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" VerticalAlignment="Center"
                Background="White" CornerRadius="12"
                Padding="48,40"
                Margin="0,40">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel>

                <TextBlock Text="UniLineGo" FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#2C3E50"
                           FontFamily="Segoe UI" Margin="0,0,0,8"/>
                <TextBlock Text="Увійдіть до свого акаунту" FontSize="14"
                           HorizontalAlignment="Center" Foreground="#7F8C8D"
                           FontFamily="Segoe UI" Margin="0,0,0,36"/>

                <TextBlock Text="Email" FontSize="13" Foreground="#2C3E50"
                           FontFamily="Segoe UI" Margin="0,0,0,6"/>
                <TextBox x:Name="EmailBox" Height="42" Padding="12,10"
                         FontSize="14" FontFamily="Segoe UI"
                         BorderBrush="#DDE1E7" BorderThickness="1"
                         Background="#FAFAFA"/>

                <TextBlock Text="Пароль" FontSize="13" Foreground="#2C3E50"
                           FontFamily="Segoe UI" Margin="0,16,0,6"/>
                <PasswordBox x:Name="PasswordBox" Height="42" Padding="12,10"
                             FontSize="14" FontFamily="Segoe UI"
                             BorderBrush="#DDE1E7" BorderThickness="1"
                             Background="#FAFAFA"/>

                <TextBlock x:Name="ErrorText" Foreground="#E74C3C" FontSize="12"
                           FontFamily="Segoe UI" Margin="0,10,0,0"
                           TextWrapping="Wrap" Visibility="Collapsed"/>

                <Button Content="Увійти" Height="44" Margin="0,24,0,0"
                        Background="#2C3E50" Foreground="White"
                        FontSize="15" FontFamily="Segoe UI"
                        FontWeight="SemiBold" BorderThickness="0"
                        Cursor="Hand" Click="LoginButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2C3E50"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="0,10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <TextBlock Text="Немає акаунту? " Foreground="#7F8C8D"
                               FontSize="13" FontFamily="Segoe UI"/>
                    <TextBlock Text="Зареєструватись" Foreground="#2980B9"
                               FontSize="13" FontFamily="Segoe UI"
                               Cursor="Hand" TextDecorations="Underline"
                               MouseLeftButtonUp="GoToRegister_Click"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>