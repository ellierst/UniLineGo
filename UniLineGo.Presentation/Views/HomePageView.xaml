<UserControl x:Class="UniLineGo.Presentation.Views.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F2F0" Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Сьогодні"
                   FontSize="28" FontWeight="Bold"
                   Foreground="#3D3047"
                   Margin="0,0,0,24"/>

        <!-- Stat Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Всього завдань -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#6B5B7B"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="#EDE8ED" CornerRadius="8"
                            Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock Text="📋" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TotalCount" Text="0"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#3D3047" Margin="0,0,0,2"/>
                    <TextBlock Text="Всього завдань" FontSize="12" Foreground="#9A8A9E"/>
                </StackPanel>
            </Border>

            <!-- Виконано -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#6B5B7B"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="#E8F5E9" CornerRadius="8"
                            Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock Text="✓" FontSize="18" FontWeight="Bold" Foreground="#388E3C"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="DoneCount" Text="0"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#388E3C" Margin="0,0,0,2"/>
                    <TextBlock Text="Виконано" FontSize="12" Foreground="#9A8A9E"/>
                </StackPanel>
            </Border>

            <!-- На виконання -->
            <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#6B5B7B"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="#FFF3E0" CornerRadius="8"
                            Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock Text="⏳" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="PendingCount" Text="0"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#E65100" Margin="0,0,0,2"/>
                    <TextBlock Text="На виконання" FontSize="12" Foreground="#9A8A9E"/>
                </StackPanel>
            </Border>

            <!-- Без дедлайну -->
            <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="20,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#6B5B7B"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="#F0EBF4" CornerRadius="8"
                            Width="36" Height="36" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock Text="∞" FontSize="20" FontWeight="Bold" Foreground="#9A8A9E"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="NoDeadlineCount" Text="0"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#9A8A9E" Margin="0,0,0,2"/>
                    <TextBlock Text="Без дедлайну" FontSize="12" Foreground="#9A8A9E"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Section Header -->
        <TextBlock Grid.Row="2"
                   Text="Найближчі дедлайни"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="#3D3047"
                   Margin="0,0,0,12"/>

        <!-- Deadlines Card -->
        <Border Grid.Row="3" Background="White" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#6B5B7B"/>
            </Border.Effect>
            <Grid>
                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="🎉" FontSize="36"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Немає найближчих дедлайнів"
                               FontSize="14" Foreground="#9A8A9E"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Clickable list -->
                <ScrollViewer x:Name="DeadlineScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,8">
                    <ItemsControl x:Name="DeadlineList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Tag stores task Id for click lookup -->
                                <Border Padding="20,12"
                                        BorderBrush="#F0EBF4"
                                        BorderThickness="0,0,0,1"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        Tag="{Binding Id}"
                                        MouseLeftButtonUp="DeadlineRow_Click"
                                        MouseEnter="DeadlineRow_MouseEnter"
                                        MouseLeave="DeadlineRow_MouseLeave">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="14" FontWeight="Medium"
                                                       Foreground="#3D3047"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DeadlineText}"
                                                       FontSize="12" Foreground="#B0A4BA"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                CornerRadius="12" Padding="12,4"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UrgencyTag}" Value="Сьогодні">
                                                            <Setter Property="Background" Value="#FDECEA"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UrgencyTag}" Value="Завтра">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding UrgencyTag}" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UrgencyTag}" Value="Сьогодні">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Add Task Button -->
        <Button Grid.Row="4" Height="48" Margin="0,16,0,0"
                Cursor="Hand" Click="AddTask_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="#a78dc4" CornerRadius="10">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="+ " FontSize="16" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Додати завдання" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#8e75a9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</UserControl>
