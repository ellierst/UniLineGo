<UserControl x:Class="UniLineGo.Presentation.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#EBDEC0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="460"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="1" VerticalAlignment="Center"
                Background="#FAF7F0" CornerRadius="16"
                Padding="48,44" Margin="0,40">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.15" Color="#768E78"/>
            </Border.Effect>
            <StackPanel>

                <TextBlock Text="Мій профіль" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#768E78"
                           FontFamily="Segoe UI" Margin="0,0,0,32"/>

                <TextBlock Text="Ім'я користувача" FontSize="13" Foreground="#768E78"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox" Height="44" Padding="14,10"
                         FontSize="14" FontFamily="Segoe UI"
                         BorderBrush="#C6C09C" BorderThickness="1.5" Background="#FDFBF7"/>

                <TextBlock Text="Email" FontSize="13" Foreground="#768E78"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <TextBox x:Name="EmailBox" Height="44" Padding="14,10"
                         FontSize="14" FontFamily="Segoe UI"
                         BorderBrush="#C6C09C" BorderThickness="1.5" Background="#FDFBF7"/>

                <TextBlock Text="Новий пароль"
                           FontSize="13" Foreground="#768E78"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <PasswordBox x:Name="NewPasswordBox" Height="44" Padding="14,10"
                             FontSize="14" FontFamily="Segoe UI"
                             BorderBrush="#C6C09C" BorderThickness="1.5" Background="#FDFBF7"/>

                <TextBlock Text="Підтвердіть новий пароль" FontSize="13" Foreground="#768E78"
                           FontFamily="Segoe UI" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="44" Padding="14,10"
                             FontSize="14" FontFamily="Segoe UI"
                             BorderBrush="#C6C09C" BorderThickness="1.5" Background="#FDFBF7"/>

                <TextBlock x:Name="MessageText" FontSize="12" FontFamily="Segoe UI"
                           Margin="0,10,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                <Button Content="Зберегти зміни" Height="46" Margin="0,24,0,0"
                        FontSize="15" FontFamily="Segoe UI" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="SaveButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#768E78" CornerRadius="8" Padding="0,12">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="← Назад" Height="36" Margin="0,8,0,0"
                        FontSize="13" FontFamily="Segoe UI"
                        BorderThickness="0" Cursor="Hand"
                        Background="Transparent" Foreground="#C6C09C"
                        Click="BackButton_Click"/>

                <Separator Background="#C6C09C" Margin="0,20" Opacity="0.4"/>

                <Button Content="Вийти з акаунту" Height="46"
                        FontSize="15" FontFamily="Segoe UI" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Click="LogoutButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#E79897" CornerRadius="8" Padding="0,12">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>